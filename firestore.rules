rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin check: Now looks at a private 'admins' collection for better privacy
    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && request.auth.uid == userId
                    // Prevent users from setting their own admin/ban status
                    && !request.resource.data.keys().hasAny(['isAdmin', 'isBanned'])
                    // Impersonation Prevention: Block reserved keywords in the display name
                    && !request.resource.data.displayName.lower().matches('.*(admin|support|system|official|pelegrin|volunteer|moderator|staff).*')
                    && request.resource.data.uid == userId;

      allow update: if isSignedIn() && request.auth.uid == userId 
                    // ENFORCE: Use only the user model fields, block admin escalation
                    && !request.resource.data.keys().hasAny(['isAdmin', 'isBanned'])
                    // Impersonation Prevention: Block reserved keywords in name changes
                    && (!request.resource.data.keys().hasAny(['displayName']) || !request.resource.data.displayName.lower().matches('.*(admin|support|system|official|pelegrin|volunteer|moderator|staff).*'))
                    // ENFORCE: Strict size limits to prevent resource abuse (billing protection)
                    && (!request.resource.data.keys().hasAny(['bio']) || request.resource.data.bio.size() <= 1000)
                    && (!request.resource.data.keys().hasAny(['displayName']) || request.resource.data.displayName.size() <= 60);


      allow delete: if isAdmin();
    }

    // Restricted Admin Collection (Hidden from regular users)
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // Only manageable via Firebase Console/Cloud Functions
    }

    // ── Reports (Abuse Prevention) ───────────────────────────────────────────
    match /reports/{reportId} {
      allow read, update, delete: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterUid == request.auth.uid;
    }

    // ── Connections ──────────────────────────────────────────────────────────
    match /connections/{connectionId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.userIds);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds;
      
      allow update: if isSignedIn() 
                    && request.auth.uid in resource.data.userIds
                    && (
                      // Preventing self-acceptance: caller must NOT be the original sender
                      (request.resource.data.status == 'accepted' && request.auth.uid != resource.data.senderId)
                      || request.resource.data.status != 'accepted'
                    );
      allow delete: if isAdmin();
    }

    // ── Pax (Greetings) ─────────────────────────────────────────────────────
    match /paxes/{paxId} {
      allow read: if isSignedIn() && (
        resource == null ||
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.fromUid;
    }
    
    // ── Chats & Messages ────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn() && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        allow create: if isSignedIn() 
                      && request.resource.data.senderUid == request.auth.uid 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 1000;

        // VULNERABILITY FIX: Prevent message text/sender tampering
        // Only allow updating the 'read' status
        allow update: if isSignedIn() 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    // Block all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Enable collectionGroup query for self-sent messages (for rate-limit checks)
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn() && resource.data.senderUid == request.auth.uid;
    }
  }
}
